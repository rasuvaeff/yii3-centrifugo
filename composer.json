{
    "name": "rasuvaeff/yii3-centrifugo",
    "description": "Centrifugo v6 integration for Yii3: server API client, JWT token issuer, and PSR-15 proxy event handlers",
    "license": "BSD-3-Clause",
    "type": "library",
    "keywords": [
        "centrifugo",
        "realtime",
        "websocket",
        "yii3"
    ],
    "authors": [
        {
            "name": "Victor Razuvaev",
            "email": "rasuvaeff@gmail.com"
        }
    ],
    "homepage": "https://github.com/rasuvaeff/yii3-centrifugo",
    "support": {
        "issues": "https://github.com/rasuvaeff/yii3-centrifugo/issues",
        "source": "https://github.com/rasuvaeff/yii3-centrifugo"
    },
    "require": {
        "php": "8.3 - 8.5",
        "lcobucci/jwt": "^5.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.51",
        "friendsofphp/php-cs-fixer": "^3.95",
        "infection/infection": "^0.33",
        "maglnet/composer-require-checker": "^4.17",
        "nyholm/psr7": "^1.8",
        "rector/rector": "^2.4",
        "roave/backward-compatibility-check": "^8.0",
        "testo/bridge-infection": "^0.1.6",
        "testo/testo": "^0.10.25",
        "vimeo/psalm": "^6.16"
    },
    "suggest": {
        "centrifugal/phpcent": "Official low-level Centrifugo HTTP API client (alternative to the bundled PSR-18 client)",
        "yiisoft/yii-runner-http": "Run Yii3 application over HTTP"
    },
    "autoload": {
        "psr-4": {
            "Rasuvaeff\\Yii3Centrifugo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rasuvaeff\\Yii3Centrifugo\\Benchmarks\\": "benchmarks/",
            "Rasuvaeff\\Yii3Centrifugo\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true
        },
        "platform": {
            "ext-bcmath": "1.0.0",
            "ext-intl": "1.0.0"
        },
        "sort-packages": true
    },
    "extra": {
        "config-plugin": {
            "di": "config/di.php",
            "params": "config/params.php"
        },
        "config-plugin-options": {
            "source-directory": "config"
        }
    },
    "scripts": {
        "bc-check": "roave-backward-compatibility-check",
        "bench": "testo --suite=Benchmarks -vv",
        "build": [
            "@composer validate --strict",
            "@composer normalize --dry-run",
            "@require-checker",
            "@cs",
            "@psalm",
            "@test"
        ],
        "cs": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php",
        "cs:fix": "php-cs-fixer fix --diff --config=.php-cs-fixer.php",
        "mutation": "infection --threads=max",
        "psalm": "psalm --no-cache",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process",
        "release-check": [
            "@build",
            "@rector",
            "@bc-check"
        ],
        "require-checker": "composer-require-checker check composer.json",
        "test": "testo --suite=Unit",
        "test:coverage": "testo --suite=Unit --coverage --coverage-clover=build/coverage.xml",
        "test:coverage:ci": "testo --suite=Unit --coverage-clover=build/coverage.xml"
    }
}
